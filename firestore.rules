rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'meals', 'groceries', 'pantryIngredients', 'favorites', 'updatedAt']) &&
             (!('uid' in data) || data.uid is string) &&
             (!('meals' in data) || (data.meals is string && data.meals.size() < 1000000)) &&
             (!('groceries' in data) || (data.groceries is string && data.groceries.size() < 1000000)) &&
             (!('pantryIngredients' in data) || (data.pantryIngredients is list && data.pantryIngredients.size() < 1000)) &&
             (!('favorites' in data) || (data.favorites is string && data.favorites.size() < 1000000)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && uidUnchanged() && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && uidNotModified() && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
